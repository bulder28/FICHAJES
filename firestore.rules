From 17bcf10b4a78185cff5f5f68bab0a8edbc2e3e96 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Iker=20Divar=20D=C3=ADaz?= <iker@bulder28.local>
Date: Wed, 1 Jul 2026 18:01:26 +0000
Subject: [PATCH] fix(firestore): reglas de operarios demasiado estrictas
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Las reglas exigían campos ['nombre','createdAt'] y prohibían cualquier
otro campo. Esto rechazaba silenciosamente TODOS los writes reales de
la app (alta manual desde configuración, importador Excel, sync líneas),
que usan idTrabajador/isETT/agencia/seccionBase/lineaBase/turnoBase/updatedAt.

Se relajan a: exigir solo un 'nombre' string de 3-100 chars. El resto
de campos quedan libres para adaptarse a cada flujo.
---
 firestore.rules | 12 +++++++-----
 1 file changed, 7 insertions(+), 5 deletions(-)

diff --git a/firestore.rules b/firestore.rules
index 6314c7b..3d06276 100644
--- a/firestore.rules
+++ b/firestore.rules
@@ -58,14 +58,16 @@ service cloud.firestore {
       allow delete: if true; // Mantener de forma temporal para permitir el funcionamiento actual
     }
 
-    // REGLAS PARA LA COLECCIÓN DE OPERARIOS (AUTOCLEAN / AUTOCAMPOS)
+    // REGLAS PARA LA COLECCIÓN DE OPERARIOS
+    // Se permite la escritura siempre que exista un 'nombre' válido (string 3-100 chars).
+    // El resto de campos (idTrabajador, isETT, agencia, seccionBase/Asignada,
+    // lineaBase, turnoBase, createdAt, updatedAt, tipo, ...) son opcionales y
+    // pueden variar según el origen (alta manual, import Excel, sync líneas).
     match /operarios/{operarioId} {
       allow read: if true;
-      allow write: if request.resource.data.keys().hasAll(['nombre', 'createdAt'])
-                   && request.resource.data.nombre is string
+      allow write: if request.resource.data.nombre is string
                    && request.resource.data.nombre.size() >= 3
-                   && request.resource.data.nombre.size() <= 100
-                   && request.resource.data.createdAt is int;
+                   && request.resource.data.nombre.size() <= 100;
       allow delete: if true; // Permitir borrar operarios si fuera necesario
     }
   }
-- 
2.43.0
