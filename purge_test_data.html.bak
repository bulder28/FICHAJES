<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STULZ - Purga de Datos (Script Temporal)</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 2rem; background: #0f172a; color: white; }
        .box { background: #1e293b; padding: 2rem; border-radius: 8px; border: 1px solid #334155; max-width: 600px; margin: 0 auto; }
        h1 { color: #ef4444; }
        button { background: #ef4444; color: white; border: none; padding: 1rem 2rem; font-size: 1.1rem; border-radius: 4px; cursor: pointer; font-weight: bold; }
        button:hover { background: #b91c1c; }
        #log { margin-top: 2rem; padding: 1rem; background: #000; border-radius: 4px; font-family: monospace; height: 300px; overflow-y: auto; }
        .log-line { margin: 0.25rem 0; color: #10b981; }
        .log-error { color: #ef4444; }
    </style>
</head>
<body>
    <div class="box">
        <h1>⚠️ Peligro: Borrado de Base de Datos</h1>
        <p>Este script se conectará a Firestore y eliminará todos los documentos de las colecciones <strong>fichajes</strong> y <strong>operarios</strong>. Esta acción es irreversible.</p>
        <button id="btn-purge">Sí, PURGAR DATOS AHORA</button>
        <div id="log"></div>
    </div>

    <!-- Firebase SDK Compat -->
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>
    <script src="shared.js"></script>
    
    <script>
        const logEl = document.getElementById('log');
        const btn = document.getElementById('btn-purge');

        function logMsg(msg, isError = false) {
            const p = document.createElement('div');
            p.className = isError ? 'log-line log-error' : 'log-line';
            p.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
            logEl.appendChild(p);
            logEl.scrollTop = logEl.scrollHeight;
        }

        async function purgeCollection(collectionName) {
            logMsg(`Iniciando purga de '${collectionName}'...`);
            const snapshot = await db.collection(collectionName).get();
            
            if (snapshot.empty) {
                logMsg(`La colección '${collectionName}' ya está vacía.`);
                return;
            }

            logMsg(`Encontrados ${snapshot.size} documentos en '${collectionName}'. Borrando...`);
            
            const batchSize = 50;
            let count = 0;
            
            // Delete docs in sequence to avoid rate limits
            for (const doc of snapshot.docs) {
                await db.collection(collectionName).doc(doc.id).delete();
                count++;
                if (count % 10 === 0) logMsg(`  ...borrados ${count}/${snapshot.size}`);
            }
            logMsg(`Colección '${collectionName}' vaciada con éxito (${count} docs).`);
        }

        btn.addEventListener('click', async () => {
            const confirmacion = confirm("¿Estás absolutamente seguro de que quieres borrar TODOS LOS FICHAJES Y OPERARIOS?");
            if (!confirmacion) return;

            btn.disabled = true;
            btn.style.background = '#475569';
            btn.textContent = 'Borrando...';
            
            try {
                await purgeCollection('fichajes');
                await purgeCollection('operarios');
                logMsg("========================================");
                logMsg("PURGA COMPLETADA. YA PUEDES CERRAR ESTA PESTAÑA.");
                alert("Limpieza completada. Cierra esta ventana e informa al asistente para borrar este script.");
            } catch (err) {
                logMsg(`Error durante el borrado: ${err.message}`, true);
            }
        });
    </script>
</body>
</html>
